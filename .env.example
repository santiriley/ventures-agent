# Carica Scout — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=        # console.anthropic.com → API Keys
NOTION_API_KEY=           # notion.so/my-integrations
NOTION_DB_LEADS=          # From Notion URL: notion.so/{THIS_PART}?v=...

# ── Optional (improves quality) ─────────────────────────────────────────────
TAVILY_API_KEY=           # app.tavily.com → API Keys (free tier available)
                          # Enables web search during enrichment — highly recommended
HUNTER_API_KEY=           # hunter.io → free tier (optional, improves contact finding)
NOTION_DB_EVENTS=         # Second database for events (optional)
NOTION_DB_DISRUPTION=     # Disruption Research database for sector memos (optional — see NOTION_SETUP.md §4)
